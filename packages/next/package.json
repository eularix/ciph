{
  "name": "@ciph/nextjs",
  "version": "0.1.0",
  "description": "Next.js encryption library for transparent HTTP encryption",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@ciph/core": "workspace:*",
    "@ciph/client": "workspace:*",
    "@ciph/react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=16.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
