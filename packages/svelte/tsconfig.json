{
  "compilerOptions": {
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src", "*.ts", "*.svelte"],
  "exclude": ["dist", "node_modules"]
}
