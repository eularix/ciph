{
  "name": "@ciph/vue",
  "version": "1.6.0-beta.1",
  "description": "Vue 3 client for Ciph transparent HTTP encryption (ECDH v2)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo 'no tests'",
    "test:coverage": "echo 'no tests'",
    "type-check": "vue-tsc --noEmit",
    "lint": "echo 'no lint'"
  },
  "peerDependencies": {
    "@ciph/core": "workspace:*",
    "axios": "^1.0.0",
    "vue": ">=3.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ciph/core": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.9.0",
    "axios": "^1.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}
