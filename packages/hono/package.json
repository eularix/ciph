{
  "name": "@ciph/hono",
  "version": "2.0.0",
  "description": "Transparent HTTP encryption middleware for Hono in Ciph",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'no lint'"
  },
  "peerDependencies": {
    "@ciph/core": "0.7.0",
    "hono": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@ciph/client": "2.0.0",
    "@ciph/core": "0.7.0",
    "@hono/node-server": "^1.13.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.3",
    "hono": "^4.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
